# Utility command for edit_cache

build CMakeFiles/edit_cache.util: CUSTOM_COMMAND
  COMMAND = C:\WINDOWS\system32\cmd.exe /C "cd /D D:\stm32_hal_program\FreeRtos\OV_watch_01\build\MinSizeRel && D:\STM32CubeCLT\STM32CubeCLT\STM32CubeCLT_1.19.0\CMake\bin\cmake-gui.exe -SD:\stm32_hal_program\FreeRtos\OV_watch_01 -BD:\stm32_hal_program\FreeRtos\OV_watch_01\build\MinSizeRel"
  DESC = Running CMake cache editor...
  pool = console
  restat = 1

build edit_cache: phony CMakeFiles/edit_cache.util


